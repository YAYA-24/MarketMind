# DeepSeek 大模型 API
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Tavily 联网搜索 API (https://tavily.com 注册获取)
TAVILY_API_KEY=your-tavily-api-key-here

# RAG Embedding: bge（BGE 中文，默认）| default（ChromaDB 内置）
# EMBEDDING_MODEL=bge

# Query Expansion: 1 启用同义扩写 + RRF 融合，0 关闭
# ENABLE_QUERY_EXPANSION=1

# 混合检索: 1 启用 Dense+BM25（金融关键词敏感），0 仅向量
# ENABLE_HYBRID_SEARCH=1
